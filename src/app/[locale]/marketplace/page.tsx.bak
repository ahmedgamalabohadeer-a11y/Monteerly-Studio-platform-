'use client'
import React, { useState, useEffect } from 'react';
import { Briefcase, Star, ShieldCheck, Search } from 'lucide-react';
import { supabase } from '@/lib/supabase';
import Image from 'next/image';
import Link from 'next/link';

export default function MarketplacePage() {
  const [freelancers, setFreelancers] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    async function fetchTalent() {
      // الربط الحقيقي بـ Supabase بدلاً من البيانات الثابتة
      const { data } = await supabase.from('users').select('*').eq('role', 'freelancer').limit(10);
      if (data) setFreelancers(data);
      setLoading(false);
    }
    fetchTalent();
  }, []);

  return (
    <div className="min-h-screen bg-[#05050A] text-slate-50 p-8 font-sans" dir="rtl">
      <div className="max-w-7xl mx-auto">
        <h1 className="text-4xl font-black mb-8 flex items-center gap-3">
           <Briefcase className="text-indigo-500" /> سوق النُخب الإبداعية (مربوط بـ Supabase)
        </h1>
        
        {/* شريط البحث المربوط */}
        <div className="bg-[#0A0A0F] p-4 rounded-2xl border border-white/10 mb-8 flex items-center gap-4">
           <Search className="text-slate-400" />
           <input type="text" placeholder="ابحث في قاعدة بيانات النخب..." className="bg-transparent w-full outline-none" />
        </div>

        {loading ? <p>جاري تحميل النخب من قاعدة البيانات...</p> : (
           <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
             {freelancers.map((f: any) => (
               <div key={f.id} className="bg-[#0A0A0F] border border-white/5 p-6 rounded-[2rem]">
                 <h3 className="font-black text-lg">{f.email}</h3>
                 <p className="text-indigo-400 text-sm">{f.role}</p>
               </div>
             ))}
           </div>
        )}
      </div>
    </div>
  );
}
